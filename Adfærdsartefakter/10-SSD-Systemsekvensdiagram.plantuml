@startuml SSD 
title <u>UC1: Opret profil til podcast episode  </u>

Actor ":Podcast Owner" as PO
participant "<u>:System</u>" as System

PO -> System: vælgOpretProfil()

System -->> PO: Viser Formular

PO -> System: gemProfil (navn, telefon, email)

System -->> PO: Validering af profilinformationer

opt Hvis profil er en borger
    PO -> System: tilføjBorgerInformationer(CPR,jobStatus, osv.)
    
    loop Valideringsfejl eller profil findes (BorgerInformationer)
        System -->> PO: Viser Fejlmeddelelse
        PO -> System: retValideringsfejl(Borgerinformationer rettes)
    else Succes
        PO -> System: gemProfil()
        
    end
end

System -->> PO: Profil gemt


hide footbox

@enduml