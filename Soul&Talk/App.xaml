<Application x:Class="Soul_Talk.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:view="clr-namespace:Soul_Talk.View"
             xmlns:viewModel="clr-namespace:Soul_Talk.ViewModel">

    <Application.Resources>

        <Style TargetType="Window">
            <Setter Property="FontFamily" Value="Book Antiqua" />
        </Style>
        <Style TargetType="UserControl">
            <Setter Property="FontFamily" Value="Book Antiqua" />
        </Style>

        <DataTemplate DataType="{x:Type viewModel:GuestViewModel}">
            <view:GuestView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModel:CreateGuestViewModel}">
            <view:CreateGuestView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModel:PodcastEpisodeViewModel}">
            <view:PodcastEpisodeView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModel:CreatePodcastEpisodeViewModel}">
            <view:CreatePodcastEpisodeView/>
        </DataTemplate>

    </Application.Resources>
    
</Application>