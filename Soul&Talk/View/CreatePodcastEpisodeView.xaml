<UserControl x:Class="Soul_Talk.View.CreatePodcastEpisodeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="40" Background="White">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Opret podcast episode"
                           FontSize="28"
                           FontWeight="Bold" />

                <TextBlock Text="Udfyld informationerne for den nye podcast episode og tilføj eventuelle gæster."
                           FontSize="14"
                           Foreground="#666666"
                           Margin="0,8,0,0"/>
            </StackPanel>

        </Grid>

        <!-- Podcast Form -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">

            <StackPanel Width="620"
                        HorizontalAlignment="Left">

                <!-- Episode Details Section -->
                <Border BorderBrush="#DDDDDD"
                        BorderThickness="1"
                        Padding="20"
                        Background="White"
                        Margin="0,0,0,20" Height="655">

                    <StackPanel>

                        <TextBlock Text="Episodeoplysninger"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,20" FontFamily="Book Antiqua"/>

                        <TextBlock Text="Titel"
                                   FontWeight="SemiBold"/>
                        <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                                 Height="32"
                                 Margin="0,5,0,15"/>

                        <TextBlock Text="Dato"
                                   FontWeight="SemiBold"/>
                        <DatePicker SelectedDate="{Binding Date, UpdateSourceTrigger=PropertyChanged}"
                                    DisplayDate="{Binding Date}"
                                    Height="32"
                                    Margin="0,5,0,15"/>

                        <TextBlock Text="Varighed i timer"
                                   FontWeight="SemiBold"/>
                        <TextBox Text="{Binding DurationHours, UpdateSourceTrigger=PropertyChanged}"
                                 Height="32"
                                 Margin="0,5,0,15"/>

                        <TextBlock Text="Status"
                                   FontWeight="SemiBold"/>
                        <ComboBox ItemsSource="{Binding StatusOptions}"
                                   SelectedItem="{Binding Status, UpdateSourceTrigger=PropertyChanged}"
                                   Height="32"
                                   Margin="0,5,0,15"/>

                        <TextBlock Text="Mødested"
                                   FontWeight="SemiBold"/>
                        <TextBox Text="{Binding MeetingPlace, UpdateSourceTrigger=PropertyChanged}"
                                 Height="32"
                                 Margin="0,5,0,15"/>

                        <TextBlock Text="Sagsbehandler"
                                      FontWeight="SemiBold"/>
                        <TextBox Text="{Binding CaseOfficerName, UpdateSourceTrigger=PropertyChanged}"
                                  Height="32"
                                  Margin="0,5,0,15"/>

                        <TextBlock Text="Note"
                                   FontWeight="SemiBold"/>
                        <TextBox Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}"
                                 Height="130"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Margin="0,5,0,0"/>

                    </StackPanel>
                </Border>

                <!-- Associated Guests List -->
                <Border BorderBrush="#DDDDDD"
                        BorderThickness="1"
                        Padding="20"
                        Background="White"
                        Margin="0,0,0,20">

                    <StackPanel>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Tilknyttede gæster"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" FontFamily="Book Antiqua"/>

                            <Button Grid.Column="1"
                                    Content="Tilføj gæst"
                                    Width="110"
                                    Height="30"
                                    Command="{Binding AddGuestCommand}"
                                    Background="White"
                                    BorderBrush="Black" TextBlock.FontFamily="Book Antiqua"/>
                        </Grid>

                        <ListBox ItemsSource="{Binding SelectedGuests}"
                                 SelectedItem="{Binding SelectedEpisodeGuest}"
                                 MinHeight="100"
                                 MaxHeight="180"
                                 Margin="0,0,0,10">

                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10"
                                            Margin="0,0,0,8"
                                            BorderBrush="#E0E0E0"
                                            BorderThickness="1"
                                            Background="White">

                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="SemiBold"/>

                                            <TextBlock Text="{Binding Email}"
                                                       Foreground="#666666"
                                                       FontSize="12"/>
                                        </StackPanel>

                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>

                        </ListBox>

                        <Button Content="Fjern valgt gæst"
                                Width="130"
                                Height="30"
                                HorizontalAlignment="Left"
                                Command="{Binding RemoveSelectedEpisodeGuestCommand}"
                                Background="White"
                                BorderBrush="Black" TextBlock.FontFamily="Book Antiqua"/>

                    </StackPanel>
                </Border>

                <!-- Action Buttons -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left">

                    <Button Content="Gem episode"
                            Width="120"
                            Height="34"
                            Margin="0,0,10,0"
                            Command="{Binding SavePodcastEpisodeCommand}"
                            Background="White"
                            BorderBrush="Black" TextBlock.FontFamily="Book Antiqua"/>

                    <Button Content="Annuller"
                            Width="120"
                            Height="34"
                            Command="{Binding CancelCommand}"
                            Background="White"
                            BorderBrush="Black" TextBlock.FontFamily="Book Antiqua"/>

                </StackPanel>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>