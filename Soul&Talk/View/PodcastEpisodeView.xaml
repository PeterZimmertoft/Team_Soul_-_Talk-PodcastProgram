<UserControl x:Class="Soul_Talk.View.PodcastEpisodeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="40" Background="White">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Podcast episoder"
                       FontSize="28"
                       FontWeight="Bold"
                       VerticalAlignment="Center" />

            <Button Grid.Column="1"
                    Content="Tilbage"
                    Width="90"
                    Height="28"
                    Command="{Binding BackCommand}"
                    Background="White"
                    BorderBrush="Black" />
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="25"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    BorderBrush="#DDDDDD"
                    BorderThickness="1"
                    Padding="15"
                    Background="White">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Episodeliste"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Margin="0,0,0,15"
                               FontFamily="Book Antiqua"/>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding PodcastEpisodes}"
                             SelectedItem="{Binding SelectedPodcastEpisode}">

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10"
                                        Margin="0,0,0,8"
                                        BorderBrush="#E0E0E0"
                                        BorderThickness="1"
                                        Background="White">

                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap"/>

                                        <TextBlock Text="{Binding Date, StringFormat={}{0:dd-MM-yyyy}}"
                                         FontSize="12"
                                         Foreground="#666666"
                                         Margin="0,4,0,0"/>
                                    </StackPanel>

                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>

                    </ListBox>

                </Grid>
            </Border>

            <Border Grid.Column="2"
                    BorderBrush="#DDDDDD"
                    BorderThickness="1"
                    Padding="20"
                    Background="White">

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <TextBlock Text="Handlinger"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,20"
                                   FontFamily="Book Antiqua"/>

                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,0,25">

                            <Button Content="Opret episode"
                                    Width="120"
                                    Height="30"
                                    Margin="0,0,10,0"
                                    Command="{Binding CreatePodcastEpisodeCommand}"
                                    Background="White"
                                    BorderBrush="Black"
                                    TextBlock.FontFamily="Book Antiqua"/>

                            <Button Content="Slet episode"
                                    Width="110"
                                    Height="30"
                                    Command="{Binding DeletePodcastEpisodeCommand}"
                                    Background="#FFFF7575"
                                    BorderBrush="Black"
                                    TextBlock.FontFamily="Book Antiqua"/>

                        </StackPanel>

                        <Border BorderBrush="#E0E0E0"
                                BorderThickness="1"
                                Padding="15"
                                Margin="0,0,0,15"
                                Background="White">

                            <StackPanel>

                                <TextBlock Text="Valgt episode:"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,15"
                                           FontFamily="Book Antiqua"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Titel:" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedPodcastEpisode.Title}" TextWrapping="Wrap" Margin="0,0,0,10"/>

                                    <TextBlock Grid.Row="1" 
                                    Grid.Column="0" 
                                    Text="Dato:" 
                                    FontWeight="SemiBold" 
                                    Margin="0,0,0,10"/>
                                    
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedPodcastEpisode.Date, StringFormat={}{0:dd-MM-yyyy}}" Margin="0,0,0,10"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Varighed:" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedPodcastEpisode.Duration}" Margin="0,0,0,10"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Status:" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedPodcastEpisode.Status}" Margin="0,0,0,10"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Mødested:" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedPodcastEpisode.MeetingPlace}" TextWrapping="Wrap" Margin="0,0,0,10"/>

                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Sagsbehandler:" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SelectedPodcastEpisode.CaseOfficerName}" Margin="0,0,0,10"/>

                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Note:" FontWeight="SemiBold" Margin="0,0,0,10"/>

                                    <Border Grid.Row="6"
                                            Grid.Column="1"
                                            BorderBrush="#DDDDDD"
                                            BorderThickness="1"
                                            Padding="10"
                                            MinHeight="90"
                                            Background="#FAFAFA"
                                            Margin="0,0,0,10">

                                        <TextBlock Text="{Binding SelectedPodcastEpisode.Note}"
                                                   TextWrapping="Wrap"/>
                                    </Border>

                                </Grid>

                            </StackPanel>
                        </Border>

                        <Border BorderBrush="#E0E0E0"
                                BorderThickness="1"
                                Padding="15"
                                Background="White">

                            <StackPanel>
                                <TextBlock Text="Tilknyttede gæster:"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,10"
                                           FontFamily="Book Antiqua"/>

                                <ListBox ItemsSource="{Binding SelectedPodcastEpisodeGuests}"
                                         MinHeight="80"
                                         MaxHeight="150">

                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="5">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Email}" FontSize="12" Foreground="#666666"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>

                                </ListBox>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
