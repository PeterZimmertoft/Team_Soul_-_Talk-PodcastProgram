<Window x:Class="Soul_Talk.View.MainView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SoulAndTalk"
        Height="600"
        Width="900"
        WindowStartupLocation="CenterScreen">

    <Grid Background="#F7F7F7">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="6*"/>
            <ColumnDefinition Width="19*"/>
        </Grid.ColumnDefinitions>

        <!-- venstre dashboard menu -->
        <Border Grid.Column="0"
                Background="White"
                BorderBrush="#D0D0D0"
                BorderThickness="0,0,1,0" Margin="0,0,683,0" Grid.ColumnSpan="2">



            <StackPanel Margin="10,20,9,20">

                <Image Source="/Assets/soulandtalk.jpg"
           Width="198"
           Height="188"
           Stretch="Uniform"
           />

                <Button Content="Gæster"
            Height="45"
            Margin="0,0,0,12"
            Command="{Binding ShowGuestViewCommand}" Background="#FFB5D5E5" FontFamily="Book Antiqua" FontSize="18"/>

                <Button Content="Opret gæst"
            Height="45"
            Margin="0,0,0,12"
            Command="{Binding ShowCreateGuestViewCommand}" Click="Button_Click" Background="#FFB5D5E5" FontFamily="Book Antiqua" FontSize="18"/>

                <Button Content="Podcast episoder"
            Height="45"
            Margin="0,0,0,12"
            Command="{Binding ShowPodcastEpisodeViewCommand}" Background="#FFB5D5E5" FontSize="18" FontFamily="Book Antiqua"/>

                <Button Content="Opret podcast episode"
            Height="45"
            Margin="0,0,0,12"
            Command="{Binding ShowCreatePodcastEpisodeViewCommand}" Background="#FFB5D5E5" FontFamily="Book Antiqua" FontSize="18" Width="197"/>

            </StackPanel>
        </Border>

        <!-- contentcontrol hvor views bliver vist -->
        <Border Grid.Column="1"
                Background="White"
                Padding="30" Margin="21,0,0,0">

            <ContentControl Content="{Binding CurrentViewModel}" Margin="-20,-20,-20,-20"/>


        </Border>

    </Grid>
</Window>