<UserControl x:Class="Soul_Talk.View.CreateGuestView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="40" Background="White">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Opret gæsteprofil"
                           FontSize="28"
                           FontWeight="Bold" FontFamily="Book Antiqua"/>

                <TextBlock Text="Indtast gæstens oplysninger. Hvis gæsten også er borger, kan ekstra informationer udfyldes."
                           FontSize="14"
                           Foreground="#666666"
                           Margin="0,8,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <Button
                    Content="Tilbage"
                    Width="90"
                    Height="28"
                    Command="{Binding CancelCommand}"
                    Background="White"
                    BorderBrush="Black" FontFamily="Book Antiqua" Grid.ColumnSpan="2" Margin="558,9,10,24"/>
        </Grid>

        <!-- Formular -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">

            <StackPanel Width="520"
                        HorizontalAlignment="Left">

                <!-- Gæsteoplysninger -->
                <Border BorderBrush="#DDDDDD"
                        BorderThickness="1"
                        Padding="20"
                        Background="White"
                        Margin="0,0,0,20">

                    <StackPanel>

                        <TextBlock Text="Basisoplysninger"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,20" FontFamily="Book Antiqua"/>

                        <TextBlock Text="Navn"
                                   FontWeight="SemiBold"/>
                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                 Height="32"
                                 Margin="0,5,0,15"/>

                        <TextBlock Text="Telefon"
                                   FontWeight="SemiBold"/>
                        <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                                 Height="32"
                                 Margin="0,5,0,15"/>

                        <TextBlock Text="Email"
                                   FontWeight="SemiBold"/>
                        <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                 Height="32"
                                 Margin="0,5,0,20"/>

                        <CheckBox Content="Gæsten er også borger"
                                  IsChecked="{Binding IsCitizen, UpdateSourceTrigger=PropertyChanged}"
                                  FontWeight="SemiBold"/>

                    </StackPanel>
                </Border>

                <!-- Borgeroplysninger -->
                <Border BorderBrush="#DDDDDD"
                        BorderThickness="1"
                        Padding="20"
                        Background="White"
                        Margin="0,0,0,20"
                        Visibility="{Binding IsCitizen, Converter={StaticResource BooleanToVisibilityConverter}}">

                    <StackPanel>

                        <TextBlock Text="Borgeroplysninger"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,20" FontFamily="Book Antiqua"/>

                        <TextBlock Text="CPR-nummer"
                                   FontWeight="SemiBold"/>
                        <TextBox Text="{Binding CprNumber, UpdateSourceTrigger=PropertyChanged}"
                                 Height="32"
                                 Margin="0,5,0,15"/>

                        <TextBlock Text="Jobstatus"
                                   FontWeight="SemiBold"/>
                        <TextBox Text="{Binding WorkStatus, UpdateSourceTrigger=PropertyChanged}"
                                 Height="32"
                                 Margin="0,5,0,15"/>

                        <TextBlock Text="Arbejdstype"
                                   FontWeight="SemiBold"/>
                        <TextBox Text="{Binding WorkType, UpdateSourceTrigger=PropertyChanged}"
                                 Height="32"
                                 Margin="0,5,0,15"/>

                        <TextBlock Text="Samtykkestatus"
                                   FontWeight="SemiBold"/>
                        <TextBox Text="{Binding ConsentStatus, UpdateSourceTrigger=PropertyChanged}"
                                 Height="32"
                                 Margin="0,5,0,15"/>

                        <TextBlock Text="Nuværende status"
                                   FontWeight="SemiBold"/>
                        <TextBox Text="{Binding CurrentStatus, UpdateSourceTrigger=PropertyChanged}"
                                 Height="32"
                                 Margin="0,5,0,15"/>

                        <TextBlock Text="Særlige hensyn"
                                   FontWeight="SemiBold"/>
                        <TextBox Text="{Binding SpecialConsiderations, UpdateSourceTrigger=PropertyChanged}"
                                 Height="90"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Margin="0,5,0,0"/>

                    </StackPanel>
                </Border>

                <!-- Knapper -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left">

                    <Button Content="Gem profil"
                            Width="120"
                            Height="34"
                            Margin="0,0,10,0"
                            Command="{Binding SaveGuestCommand}"
                            Background="White"
                            BorderBrush="Black" FontFamily="Book Antiqua"/>
                    <Button Content="Annuller"
                            Width="117"
                            Height="33"
                            Command="{Binding CancelCommand}"
                            Background="White"
                            BorderBrush="Black" FontFamily="Book Antiqua"/>

                </StackPanel>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>