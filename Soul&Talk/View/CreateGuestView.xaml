<UserControl x:Class="Soul_Talk.View.CreateGuestView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">

        <Grid Margin="40" Background="White">

            <StackPanel Width="520"
                        HorizontalAlignment="Left">

                <!-- Header -->
                <StackPanel Margin="0,0,0,25">
                    <TextBlock Text="{Binding PageTitle}"
                               FontSize="28"
                               FontWeight="Bold" />

                    <TextBlock Text="Indtast gæstens oplysninger. Hvis gæsten også er borger, kan ekstra informationer udfyldes."
                               FontSize="14"
                               Foreground="#666666"
                               Margin="0,8,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <CheckBox Content="Tilføj borgeroplysninger"
                          IsChecked="{Binding HasCitizenInfo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          FontWeight="SemiBold"
                          Margin="0,0,0,10"/>

                <Border BorderBrush="#DDDDDD"
                        BorderThickness="1"
                        Padding="20"
                        Background="White"
                        Margin="0,0,0,20">

                    <StackPanel>

                        <TextBlock Text="Basisoplysninger"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,20" FontFamily="Book Antiqua"/>

                        <TextBlock Text="Navn"
                                   FontWeight="SemiBold"/>
                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                 Height="32"
                                 Margin="0,5,0,15"/>

                        <TextBlock Text="Telefon"
                                   FontWeight="SemiBold"/>
                        <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                                 Height="32"
                                 Margin="0,5,0,15"/>

                        <TextBlock Text="Email"
                                   FontWeight="SemiBold"/>
                        <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                 Height="32"
                                 Margin="0,5,0,20"/>

                    </StackPanel>
                </Border>

                <Border BorderBrush="#DDDDDD"
                        BorderThickness="1"
                        Padding="20"
                        Background="White"
                        Margin="0,0,0,20"
                        IsEnabled="{Binding HasCitizenInfo}">

                    <StackPanel>

                        <TextBlock Text="Borgeroplysninger"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,20" FontFamily="Book Antiqua"/>

                        <TextBlock FontWeight="SemiBold">
                            <Run Text="CPR-nummer"/>
                            <Run Text=" (DDMMYY-XXXX)" Foreground="#666666"/>
                        </TextBlock>
                        <TextBox Text="{Binding CprNumber, UpdateSourceTrigger=PropertyChanged}"
                                 Height="32"
                                 Margin="0,5,0,15"/>

                        <TextBlock Text="Jobstatus"
                                   FontWeight="SemiBold"/>
                        <TextBox Text="{Binding WorkStatus, UpdateSourceTrigger=PropertyChanged}"
                                 Height="32"
                                 Margin="0,5,0,15"/>

                        <TextBlock Text="Arbejdstype"
                                   FontWeight="SemiBold"/>
                        <TextBox Text="{Binding WorkType, UpdateSourceTrigger=PropertyChanged}"
                                 Height="32"
                                 Margin="0,5,0,15"/>

                        <TextBlock Text="Samtykkestatus"
                                   FontWeight="SemiBold"/>
                        <ComboBox SelectedValue="{Binding ConsentStatus, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  SelectedValuePath="Content"
                                  Height="32"
                                  Margin="0,5,0,15">
                            <ComboBoxItem Content="Ja"/>
                            <ComboBoxItem Content="Nej"/>
                        </ComboBox>

                        <TextBlock FontWeight="SemiBold">
                            <Run Text="Nuværende status"/>
                            <Run Text=" (fx Aktiv/Passiv)" Foreground="#666666"/>
                        </TextBlock>
                        <TextBox Text="{Binding CurrentStatus, UpdateSourceTrigger=PropertyChanged}"
                                 Height="32"
                                 Margin="0,5,0,15"/>

                        <TextBlock Text="Særlige hensyn"
                                   FontWeight="SemiBold"/>
                        <TextBox Text="{Binding SpecialConsiderations, UpdateSourceTrigger=PropertyChanged}"
                                 Height="90"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Margin="0,5,0,0"/>

                    </StackPanel>
                </Border>

                <!-- Action Buttons -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left">

                    <Button Content="Gem profil"
                            Width="120"
                            Height="34"
                            Margin="0,0,10,0"
                            Command="{Binding SaveGuestCommand}"
                            Background="White"
                            BorderBrush="Black" FontFamily="Book Antiqua"/>
                    <Button Content="Annuller"
                            Width="117"
                            Height="33"
                            Command="{Binding CancelCommand}"
                            Background="White"
                            BorderBrush="Black" FontFamily="Book Antiqua"/>

                </StackPanel>

                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="Red"
                           Margin="0,12,0,0"
                           TextWrapping="Wrap"
                           FontFamily="Book Antiqua"/>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
